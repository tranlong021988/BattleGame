399   mat4 skinMatrix () {
400     vec4 joints = vec4(a_joints);
401     return getJointMatrix(joints.x) * a_weights.x
402          + getJointMatrix(joints.y) * a_weights.y
403          + getJointMatrix(joints.z) * a_weights.z
404          + getJointMatrix(joints.w) * a_weights.w;
405   }
406   
407   void CCSkin (inout vec4 position) {
408     mat4 m = skinMatrix();
409     position = m * position;
410   }
411   
412   void CCSkin (inout vec4 position, inout vec3 normal, inout vec4 tangent) {
413     mat4 m = skinMatrix();
414     position = m * position;
415     normal = (m * vec4(normal, 0.0)).xyz;
416     tangent.xyz = (m * vec4(tangent.xyz, 0.0)).xyz;
417   }
