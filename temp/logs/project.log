219   float getDisplacementWeight(int index) {
220     int quot = index / 4;
221     int remainder = index - quot * 4;
222     if (remainder == 0) {
223       return cc_displacementWeights[quot].x;
224     } else if (remainder == 1) {
225       return cc_displacementWeights[quot].y;
226     } else if (remainder == 2) {
227       return cc_displacementWeights[quot].z;
228     } else {
229       return cc_displacementWeights[quot].w;
230     }
231   }
