148 highp float decode32 (highp vec4 rgba) {
149   rgba = rgba * 255.0;
150   highp float Sign = 1.0 - (step(128.0, (rgba[3]) + 0.5)) * 2.0;
151   highp float Exponent = 2.0 * (mod(float(int((rgba[3]) + 0.5)), 128.0)) + (step(128.0, (rgba[2]) + 0.5)) - 127.0;
152   highp float Mantissa = (mod(float(int((rgba[2]) + 0.5)), 128.0)) * 65536.0 + rgba[1] * 256.0 + rgba[0] + 8388608.0;
153   return Sign * exp2(Exponent - 23.0) * Mantissa;
154 }
