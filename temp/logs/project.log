469   
470   float LinearFog(vec4 pos, vec3 cameraPos, float fogStart, float fogEnd) {
471       vec4 wPos = pos;
472       float cam_dis = distance(cameraPos, wPos.xyz);
473       return clamp((fogEnd - cam_dis) / (fogEnd - fogStart), 0., 1.);
474   }
475   float ExpFog(vec4 pos, vec3 cameraPos, float fogStart, float fogDensity, float fogAtten) {
476       vec4 wPos = pos;
477       float cam_dis = max(distance(cameraPos, wPos.xyz) - fogStart, 0.0) / fogAtten * 4.;
478       float f = exp(-cam_dis * fogDensity);
479       return f;
480   }
481   
482   float ExpSquaredFog(vec4 pos, vec3 cameraPos, float fogStart, float fogDensity, float fogAtten) {
483       vec4 wPos = pos;
484       float cam_dis = max(distance(cameraPos, wPos.xyz) - fogStart, 0.0) / fogAtten * 4.;
485       float f = exp(-cam_dis * cam_dis * fogDensity * fogDensity);
486       return f;
487   }
488   float LayeredFog(vec4 pos, vec3 cameraPos, float fogTop, float fogRange, float fogAtten) {
489       vec4 wPos = pos;
490       vec3 camWorldProj = cameraPos.xyz;
491       camWorldProj.y = 0.;
492       vec3 worldPosProj = wPos.xyz;
493       worldPosProj.y = 0.;
494       float fDeltaD = distance(worldPosProj, camWorldProj) / fogAtten * 2.0;
495       float fDeltaY, fDensityIntegral;
496       if (cameraPos.y > fogTop) {
497           if (wPos.y < fogTop) {
498               fDeltaY = (fogTop - wPos.y) / fogRange * 2.0;
499               fDensityIntegral = fDeltaY * fDeltaY * 0.5;
500           }
501           else {
502               fDeltaY = 0.;
503               fDensityIntegral = 0.;
504           }
505       }
506       else {
507           if (wPos.y < fogTop) {
508               float fDeltaA = (fogTop - cameraPos.y) / fogRange * 2.;
509               float fDeltaB = (fogTop - wPos.y) / fogRange * 2.;
510               fDeltaY = abs(fDeltaA - fDeltaB);
511               fDensityIntegral = abs((fDeltaA * fDeltaA * 0.5) - (fDeltaB * fDeltaB * 0.5));
512           }
513           else {
514               fDeltaY = abs(fogTop - cameraPos.y) / fogRange * 2.;
515               fDensityIntegral = abs(fDeltaY * fDeltaY * 0.5);
516           }
517       }
518       float fDensity;
519       if (fDeltaY != 0.) {
520           fDensity = (sqrt(1.0 + ((fDeltaD / fDeltaY) * (fDeltaD / fDeltaY)))) * fDensityIntegral;
521       }
522       else {
523           fDensity = 0.;
524       }
525       float f = exp(-fDensity);
526       return f;
527   }
528   
529 #endif
530 void CC_TRANSFER_FOG_BASE(vec4 pos, out float factor)
531 {
532 #if CC_USE_FOG == 0
533 	factor = LinearFog(pos, cc_cameraPos.xyz, cc_fogBase.x, cc_fogBase.y);
534 #elif CC_USE_FOG == 1
535 	factor = ExpFog(pos, cc_cameraPos.xyz, cc_fogBase.x, cc_fogBase.z, cc_fogAdd.z);
536 #elif CC_USE_FOG == 2
537 	factor = ExpSquaredFog(pos, cc_cameraPos.xyz, cc_fogBase.x, cc_fogBase.z, cc_fogAdd.z);
538 #elif CC_USE_FOG == 3
539 	factor = LayeredFog(pos, cc_cameraPos.xyz, cc_fogAdd.x, cc_fogAdd.y, cc_fogAdd.z);
540 #else
541 	factor = 1.0;
542 #endif
543 }
