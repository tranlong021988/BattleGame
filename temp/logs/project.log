183   vec2 getPixelLocation(vec2 textureResolution, int pixelIndex) {
184     float pixelIndexF = float(pixelIndex);
185     float x = mod(pixelIndexF, textureResolution.x);
186     float y = floor(pixelIndexF / textureResolution.x);
187     return vec2(x, y);
188   }
189   
190   vec2 getPixelCoordFromLocation(vec2 location, vec2 textureResolution) {
191     return (vec2(location.x, location.y) + .5) / textureResolution;
192   }
