401       return getJointMatrix(joints.x) * a_weights.x
402            + getJointMatrix(joints.y) * a_weights.y
403            + getJointMatrix(joints.z) * a_weights.z
404            + getJointMatrix(joints.w) * a_weights.w;
405     }
