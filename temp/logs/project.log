194   #if CC_DEVICE_SUPPORT_FLOAT_TEXTURE
195     
196       vec4 fetchVec3ArrayFromTexture(sampler2D tex, int elementIndex) {
197         int pixelIndex = elementIndex;
198         vec2 location = getPixelLocation(cc_displacementTextureInfo.xy, pixelIndex);
199         vec2 uv = getPixelCoordFromLocation(location, cc_displacementTextureInfo.xy);
200         return texture2D(tex, uv);
201       }
202     
203   #else
204     vec4 fetchVec3ArrayFromTexture(sampler2D tex, int elementIndex) {
205       int pixelIndex = elementIndex * 4;
206       vec2 location = getPixelLocation(cc_displacementTextureInfo.xy, pixelIndex);
207       vec2 x = getPixelCoordFromLocation(location + vec2(0.0, 0.0), cc_displacementTextureInfo.xy);
208       vec2 y = getPixelCoordFromLocation(location + vec2(1.0, 0.0), cc_displacementTextureInfo.xy);
209       vec2 z = getPixelCoordFromLocation(location + vec2(2.0, 0.0), cc_displacementTextureInfo.xy);
210       return vec4(
211         decode32(texture2D(tex, x)),
212         decode32(texture2D(tex, y)),
213         decode32(texture2D(tex, z)),
214         1.0
215       );
216     }
