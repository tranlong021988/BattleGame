239     for (int iTarget = 0; iTarget < CC_MORPH_TARGET_COUNT; ++iTarget) {
240       result += (fetchVec3ArrayFromTexture(tex, nVertices * iTarget + vertexIndex).rgb * getDisplacementWeight(iTarget));
