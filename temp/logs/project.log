217   float getDisplacementWeight(int index) {
218     int quot = index / 4;
219     int remainder = index - quot * 4;
220     if (remainder == 0) {
221       return cc_displacementWeights[quot].x;
222     } else if (remainder == 1) {
223       return cc_displacementWeights[quot].y;
224     } else if (remainder == 2) {
225       return cc_displacementWeights[quot].z;
226     } else {
227       return cc_displacementWeights[quot].w;
228     }
229   }
230   
231   vec3 getVec3DisplacementFromTexture(sampler2D tex, int vertexIndex) {
232   #if CC_MORPH_PRECOMPUTED
233     return fetchVec3ArrayFromTexture(tex, vertexIndex).rgb;
234   #else
235     vec3 result = vec3(0, 0, 0);
236     int nVertices = int(cc_displacementTextureInfo.z);
237     for (int iTarget = 0; iTarget < CC_MORPH_TARGET_COUNT; ++iTarget) {
238       result += (fetchVec3ArrayFromTexture(tex, nVertices * iTarget + vertexIndex).rgb * getDisplacementWeight(iTarget));
239     }
240     return result;
241   #endif
242   }
