219   float getDisplacementWeight(int index) {
220     int quot = index / 4;
221     int remainder = index - quot * 4;
222     if (remainder == 0) {
223       return cc_displacementWeights[quot].x;
224     } else if (remainder == 1) {
225       return cc_displacementWeights[quot].y;
226     } else if (remainder == 2) {
227       return cc_displacementWeights[quot].z;
228     } else {
229       return cc_displacementWeights[quot].w;
230     }
231   }
232   
233   vec3 getVec3DisplacementFromTexture(sampler2D tex, int vertexIndex) {
234   #if CC_MORPH_PRECOMPUTED
235     return fetchVec3ArrayFromTexture(tex, vertexIndex).rgb;
236   #else
237     vec3 result = vec3(0, 0, 0);
238     int nVertices = int(cc_displacementTextureInfo.z);
239     for (int iTarget = 0; iTarget < CC_MORPH_TARGET_COUNT; ++iTarget) {
240       result += (fetchVec3ArrayFromTexture(tex, nVertices * iTarget + vertexIndex).rgb * getDisplacementWeight(iTarget));
241     }
242     return result;
243   #endif
244   }
