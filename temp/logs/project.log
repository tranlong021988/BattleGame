181   vec2 getPixelLocation(vec2 textureResolution, int pixelIndex) {
182     float pixelIndexF = float(pixelIndex);
183     float x = mod(pixelIndexF, textureResolution.x);
184     float y = floor(pixelIndexF / textureResolution.x);
185     return vec2(x, y);
186   }
187   
188   vec2 getPixelCoordFromLocation(vec2 location, vec2 textureResolution) {
189     return (vec2(location.x, location.y) + .5) / textureResolution;
190   }
191   
192   #if CC_DEVICE_SUPPORT_FLOAT_TEXTURE
193     
194       vec4 fetchVec3ArrayFromTexture(sampler2D tex, int elementIndex) {
195         int pixelIndex = elementIndex;
196         vec2 location = getPixelLocation(cc_displacementTextureInfo.xy, pixelIndex);
197         vec2 uv = getPixelCoordFromLocation(location, cc_displacementTextureInfo.xy);
198         return texture2D(tex, uv);
199       }
200     
201   #else
202     vec4 fetchVec3ArrayFromTexture(sampler2D tex, int elementIndex) {
203       int pixelIndex = elementIndex * 4;
204       vec2 location = getPixelLocation(cc_displacementTextureInfo.xy, pixelIndex);
205       vec2 x = getPixelCoordFromLocation(location + vec2(0.0, 0.0), cc_displacementTextureInfo.xy);
206       vec2 y = getPixelCoordFromLocation(location + vec2(1.0, 0.0), cc_displacementTextureInfo.xy);
207       vec2 z = getPixelCoordFromLocation(location + vec2(2.0, 0.0), cc_displacementTextureInfo.xy);
208       return vec4(
209         decode32(texture2D(tex, x)),
210         decode32(texture2D(tex, y)),
211         decode32(texture2D(tex, z)),
212         1.0
213       );
214     }
215   #endif
