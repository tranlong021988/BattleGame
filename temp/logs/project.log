562 
563 varying vec2 v_uv;
564 
565    uniform vec4 tilingOffset;
566    uniform vec4 vatMin;
567    uniform vec4 vatMax;
568    uniform vec4 animParams;
569    uniform float currentFrame;
570 
571 
572 uniform sampler2D vatMap;
573 
574 vec4 vert () {
575   vec4 position;
576   CCVertInput(position);
577   float totalFrames = animParams.x;
578   float frame = mod(currentFrame, totalFrames);
579   vec2 vatUV;
580   vatUV.x = a_texCoord1.x; 
581   vatUV.y = (frame + 0.5) / totalFrames;
582   vec4 vData = texture2D(vatMap, vatUV);
583   vec3 offset = vatMin.xyz + vData.rgb * (vatMax.xyz - vatMin.xyz);
584   position.xyz += offset;
585 
586   mat4 matWorld;
587   CCGetWorldMatrix(matWorld);
588   v_uv = a_texCoord * tilingOffset.xy + tilingOffset.zw;
589 
590   #if SAMPLE_FROM_RT
591     v_uv = cc_cameraPos.w > 1.0 ? vec2(v_uv.x, 1.0 - v_uv.y) : v_uv;
592   #endif
593 
594   CC_TRANSFER_FOG(matWorld * position);
595   return cc_matProj * (cc_matView * matWorld) * position; 
596 }
