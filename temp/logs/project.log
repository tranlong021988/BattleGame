474 vec4 vert () {
475 
476   vec4 position;
477   CCVertInput(position);
478   float frameCount  = vatParam.x;
479   float vertexCount = vatParam.y;
480   float time        = vatParam.z;
481 
482   float frame = floor(time * frameCount);
483 
484   float u = (frame + 0.5) / frameCount;
485   float v = (float(gl_VertexID) + 0.5) / vertexCount;
486 
487   vec3 vatPos = texture2D(vatTex, vec2(u, v)).xyz;
488 
489   position.xyz = vatPos;
490   mat4 matWorld;
491   CCGetWorldMatrix(matWorld);
492 
493   #if USE_TEXTURE
494     v_uv = a_texCoord * tilingOffset.xy + tilingOffset.zw;
495   #endif
496 
497   return cc_matProj * (cc_matView * matWorld) * position;
498 }
