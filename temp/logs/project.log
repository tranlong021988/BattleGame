401   mat4 skinMatrix () {
402     vec4 joints = vec4(a_joints);
403     return getJointMatrix(joints.x) * a_weights.x
404          + getJointMatrix(joints.y) * a_weights.y
405          + getJointMatrix(joints.z) * a_weights.z
406          + getJointMatrix(joints.w) * a_weights.w;
407   }
408   
409   void CCSkin (inout vec4 position) {
410     mat4 m = skinMatrix();
411     position = m * position;
412   }
413   
414   void CCSkin (inout vec4 position, inout vec3 normal, inout vec4 tangent) {
415     mat4 m = skinMatrix();
416     position = m * position;
417     normal = (m * vec4(normal, 0.0)).xyz;
418     tangent.xyz = (m * vec4(tangent.xyz, 0.0)).xyz;
419   }
