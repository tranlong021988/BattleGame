479 vec4 vert () {
480 
481   vec4 position;
482   CCVertInput(position);
483 
484   float frameCount  = vatParam.x;
485   float vertexCount = vatParam.y;
486   float speed       = vatParam.z;
487   float offset      = vatParam.w;
488 
489   float time = cc_time.x * speed + offset;
490 
491   float frame = floor(mod(time, frameCount));
492   float textureWidth = 512;
493 
494   float u = (frame + 0.5) / textureWidth;
495 
496   float vertexIndex = a_texCoord1.x * vertexCount;
497   float v = (vertexIndex + 0.5) / vertexCount;
498 
499   vec3 vatPos = texture2D(vatTex, vec2(u, v)).xyz;
500   vec3 minPos = vec3(-0.2, -0.1, -0.4);
501   vec3 maxPos = vec3( 0.2,  0.1,  0.5);
502 
503   vatPos = mix(minPos, maxPos, vatPos);
504 
505   position.xyz = vatPos;
506 
507   mat4 matWorld;
508   CCGetWorldMatrix(matWorld);
509 
510   #if USE_TEXTURE
511     v_uv = a_texCoord * tilingOffset.xy + tilingOffset.zw;
512   #endif
513 
514   return cc_matProj * (cc_matView * matWorld) * position;
515 }
