CCEffect %{
  techniques:
  - name: transparent
    passes:
    - vert: billboard-vs:vert
      frag: billboard-fs:frag
      rasterizerState:
        cullMode: none
      depthStencilState:
        depthTest: true
        depthWrite: true
      blendState:
        targets:
        - blend: true
          blendSrc: src_alpha
          blendDst: one_minus_src_alpha
          blendSrcAlpha: src_alpha
          blendDstAlpha: one_minus_src_alpha
      properties:
        mainTexture:
          value: white
          editor:
            tooltip: Billboard icon sheet. Alpha controls transparency.
        sheetColumns:
          value: 1
          editor:
            min: 1
            step: 1
            tooltip: Number of icon columns in mainTexture. Shared by every banner using this material.
        sheetRows:
          value: 1
          editor:
            min: 1
            step: 1
            tooltip: Number of icon rows in mainTexture. Shared by every banner using this material.
        iconId:
          value: 0
          editor:
            min: 0
            step: 1
            tooltip: Fallback icon index when no per-instance a_billboard_icon_id is provided.
        tilingOffset:
          value: [1, 1, 0, 0]
          editor:
            tooltip: Main texture center-pivot scale and offset. xy = centered UV scale, zw = offset.
        tintColor:
          value: [1, 1, 1, 1]
          linear: true
          editor:
            type: color
            tooltip: Shared material tint. Kept as a material property so icon visibility does not depend on a custom instanced tint attribute.
        backgroundColor:
          value: [0, 0, 0, 0]
          linear: true
          editor:
            type: color
            tooltip: Shared material background fallback. Transparent texture pixels are composited over this color. Runtime team color can override this with a_billboard_bg_color.
        alphaThreshold:
          value: 0.01
          editor:
            tooltip: Fragments below this alpha are discarded before depth write, preventing transparent quad areas from blocking objects behind them.
}%

CCProgram billboard-vs %{
  precision highp float;

  #include <legacy/input>
  #include <builtin/uniforms/cc-global>
  #include <legacy/decode-base>
  #include <legacy/local-batch>

  out vec2 v_uv;
  out vec4 v_tint;
  out vec4 v_background;
  out float v_iconId;

  #if USE_INSTANCING
    in vec4 a_billboard_bg_color;
    in vec4 a_billboard_icon_id;
  #endif

  uniform Constant {
    vec4 tilingOffset;
    vec4 tintColor;
    vec4 backgroundColor;
    float alphaThreshold;
    float sheetColumns;
    float sheetRows;
    float iconId;
  };

  vec4 vert () {
    vec4 localPos;
    CCVertInput(localPos);

    mat4 matWorld;
    CCGetWorldMatrix(matWorld);

    vec3 worldCenter =
      (matWorld * vec4(0.0, 0.0, 0.0, 1.0)).xyz;

    float scaleX = length(matWorld[0].xyz);
    float scaleY = length(matWorld[1].xyz);

    vec4 viewCenter =
      cc_matView * vec4(worldCenter, 1.0);

    vec4 viewPos = viewCenter;
    viewPos.x += localPos.x * scaleX;
    viewPos.y += localPos.y * scaleY;

    v_uv =
      (a_texCoord - vec2(0.5, 0.5)) *
      tilingOffset.xy +
      vec2(0.5, 0.5) +
      tilingOffset.zw;

    v_tint = tintColor;

    #if USE_INSTANCING
      vec4 instancedBackground = a_billboard_bg_color;
      v_background = instancedBackground.a > 0.001
        ? instancedBackground
        : backgroundColor;
      v_iconId = max(0.0, a_billboard_icon_id.x);
    #else
      v_background = backgroundColor;
      v_iconId = max(0.0, iconId);
    #endif

    return cc_matProj * viewPos;
  }
}%

CCProgram billboard-fs %{
  precision highp float;

  #include <legacy/output-standard>

  in vec2 v_uv;
  in vec4 v_tint;
  in vec4 v_background;
  in float v_iconId;

  uniform sampler2D mainTexture;
  uniform Constant {
    vec4 tilingOffset;
    vec4 tintColor;
    vec4 backgroundColor;
    float alphaThreshold;
    float sheetColumns;
    float sheetRows;
    float iconId;
  };

  vec2 sampleSheetUv (vec2 uv) {
    float columns = max(1.0, floor(sheetColumns + 0.5));
    float rows = max(1.0, floor(sheetRows + 0.5));
    float maxId = max(0.0, columns * rows - 1.0);
    float selectedId = clamp(floor(v_iconId + 0.5), 0.0, maxId);
    float column = mod(selectedId, columns);
    float row = floor(selectedId / columns);

    return vec2(
      (column + uv.x) / columns,
      (rows - 1.0 - row + uv.y) / rows
    );
  }

  vec4 frag () {
    vec4 foreground = texture(mainTexture, sampleSheetUv(v_uv)) * v_tint;
    float outAlpha =
      foreground.a +
      v_background.a * (1.0 - foreground.a);

    vec3 outRgb =
      (
        foreground.rgb * foreground.a +
        v_background.rgb *
        v_background.a *
        (1.0 - foreground.a)
      ) / max(outAlpha, 0.0001);

    vec4 color = vec4(outRgb, outAlpha);
    if (color.a <= alphaThreshold) {
      discard;
    }

    return CCFragOutput(color);
  }
}%
