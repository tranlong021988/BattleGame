CCEffect %{
  techniques:
  - name: opaque
    passes:
    - vert: vat-vs:vert
      frag: unlit-fs:frag
      properties: &props
        mainTexture:    { value: grey }
        vatMap:         { value: grey }
        vatMin:         { value: [-0.2, -0.1, -0.4, 0] }
        vatMax:         { value: [0.2, 0.1, 0.5, 0] }
        vatSize:        { value: [898, 132, 0, 0] }
        currentFrame:   { value: 0 }
}%

CCProgram vat-vs %{
  precision highp float;
  #include <legacy/input>
  #include <builtin/uniforms/cc-global>
  #include <legacy/decode-base>
  #include <legacy/local-batch>
  #include <legacy/fog-vs>

  in vec2 a_texCoord1; 
  out vec2 v_uv;
  
  uniform VATConstant {
    vec4 vatMin;
    vec4 vatMax;
    vec4 vatSize; 
    float currentFrame;
  };

  uniform sampler2D vatMap;

  vec4 vert () {
    vec4 position;
    CCVertInput(position);

    float texWidth = vatSize.x;
    float texHeight = vatSize.y;

    // 1. ÉP FRAME NGUYÊN (Chống nát mesh do nội suy sai)
    float frameIdx = floor(mod(currentFrame + 0.005, texHeight));

    // 2. TÍNH UV TÂM PIXEL (Chống sai số float)
    float vID = floor(a_texCoord1.x * (texWidth - 1.0) + 0.5);
    vec2 vatUV;
    vatUV.x = (vID + 0.5) / texWidth;
    vatUV.y = (frameIdx + 0.5) / texHeight; 

    // 3. ĐỌC DỮ LIỆU RAW
    vec4 vData = texture(vatMap, vatUV);
    
    // 4. GIẢI MÃ OFFSET (Quan trọng: Kiểm soát tỷ lệ)
    // P_offset = Min + (Color * (Max - Min))
    vec3 offset = vatMin.xyz + vData.rgb * (vatMax.xyz - vatMin.xyz);

    // 5. FIX BIẾN DẠNG "TO RA": 
    // Thường do Blender dùng Unit là Meters còn Cocos dùng Unit khác, 
    // hoặc do hoán đổi trục. Hãy thử .xzy (Blender Standard)
    position.xyz += offset.xzy;

    mat4 matWorld;
    CCGetWorldMatrix(matWorld);
    v_uv = a_texCoord;

    #if SAMPLE_FROM_RT
      CC_HANDLE_RT_SAMPLE_FLIP(v_uv);
    #endif

    CC_TRANSFER_FOG(matWorld * position);
    return cc_matProj * (cc_matView * matWorld) * position;
  }
}%